/**
 * @file moonlab_build_info.h
 * @brief Compile-time build-info constants, generated by CMake.
 *
 * DO NOT EDIT: this file is regenerated from
 * @c cmake/moonlab_build_info.h.in at configure time.  The values
 * are baked into the library and every consumer, so changes to the
 * CMake template propagate through a full rebuild.
 *
 * Paired with the runtime reproducibility manifest in
 * @c src/utils/manifest.h, these constants let every benchmark
 * or demo self-describe: what source tree produced this binary,
 * which compiler, which feature flags, which platform.  Required
 * for reproducible benchmark reports (P5.18).
 */

#ifndef MOONLAB_BUILD_INFO_H
#define MOONLAB_BUILD_INFO_H

#ifdef __cplusplus
extern "C" {
#endif

/* Version string, including any pre-release suffix from VERSION.txt. */
#define MOONLAB_VERSION_STRING     "@QSIM_VERSION_FULL@"
#define MOONLAB_VERSION_MAJOR      @PROJECT_VERSION_MAJOR@
#define MOONLAB_VERSION_MINOR      @PROJECT_VERSION_MINOR@
#define MOONLAB_VERSION_PATCH      @PROJECT_VERSION_PATCH@

/* Git state captured at configure time. SHA is the full 40-char
 * commit hash, or "unknown" if the source tree isn't a git checkout.
 * DIRTY is 1 iff `git diff --quiet` was non-zero. */
#define MOONLAB_GIT_SHA            "@MOONLAB_GIT_SHA@"
#define MOONLAB_GIT_SHA_SHORT      "@MOONLAB_GIT_SHA_SHORT@"
#define MOONLAB_GIT_DIRTY          @MOONLAB_GIT_DIRTY@
#define MOONLAB_GIT_BRANCH         "@MOONLAB_GIT_BRANCH@"

/* ISO-8601 UTC build timestamp, captured at configure time. */
#define MOONLAB_BUILD_TIMESTAMP    "@MOONLAB_BUILD_TIMESTAMP@"

/* Build configuration: Release, Debug, RelWithDebInfo, etc. */
#define MOONLAB_BUILD_TYPE         "@CMAKE_BUILD_TYPE@"

/* Compiler identifier and version string (CMAKE_C_COMPILER_ID +
 * CMAKE_C_COMPILER_VERSION). */
#define MOONLAB_COMPILER_ID        "@CMAKE_C_COMPILER_ID@"
#define MOONLAB_COMPILER_VERSION   "@CMAKE_C_COMPILER_VERSION@"

/* Host platform this library was built for. */
#define MOONLAB_PLATFORM_NAME      "@QSIM_PLATFORM_NAME@"
#define MOONLAB_ARCH_NAME          "@QSIM_ARCH_NAME@"

/* Feature toggles -- 1 or 0. */
#define MOONLAB_HAS_OPENMP         @QSIM_ENABLE_OPENMP_INT@
#define MOONLAB_HAS_METAL          @QSIM_ENABLE_METAL_INT@
#define MOONLAB_HAS_OPENCL         @QSIM_ENABLE_OPENCL_INT@
#define MOONLAB_HAS_VULKAN         @QSIM_ENABLE_VULKAN_INT@
#define MOONLAB_HAS_CUQUANTUM      @QSIM_ENABLE_CUQUANTUM_INT@
#define MOONLAB_HAS_MPI            @QSIM_ENABLE_MPI_INT@
#define MOONLAB_HAS_ESHKOL         @QSIM_ENABLE_ESHKOL_INT@
#define MOONLAB_HAS_LTO            @QSIM_ENABLE_LTO_INT@
#define MOONLAB_HAS_SANITIZERS     @QSIM_ENABLE_SANITIZERS_INT@
#define MOONLAB_HAS_AVX512         @QSIM_ENABLE_AVX512_INT@
#define MOONLAB_HAS_AVX2           @QSIM_ENABLE_AVX2_INT@
#define MOONLAB_HAS_NEON           @QSIM_ENABLE_NEON_INT@
#define MOONLAB_HAS_SVE            @QSIM_ENABLE_SVE_INT@

/* Convenience string listing the enabled toggles, comma-separated. */
#define MOONLAB_ENABLED_FEATURES   "@MOONLAB_ENABLED_FEATURES@"

#ifdef __cplusplus
}
#endif

#endif /* MOONLAB_BUILD_INFO_H */
