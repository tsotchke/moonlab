/**
 * @file moonlab_features.h
 * @brief Compile-time feature configuration generated by CMake.
 *
 * Consumers of the Moonlab library should include this header to learn
 * which optional subsystems were compiled in.  Headers that declare
 * APIs from those subsystems gate their declarations on the macros
 * defined here, so users get a clean compile-time error instead of a
 * link-time unresolved-symbol when calling into a feature that wasn't
 * compiled in.
 *
 * Generated from @c src/applications/moonlab_features.h.in at CMake
 * configure time.  Do not edit the @c .h directly.
 *
 * @since v0.2.2
 * @stability  the macro names are stable; their values flip with the
 *             build configuration.
 */
#ifndef MOONLAB_FEATURES_H
#define MOONLAB_FEATURES_H

/* Build identifier (semantic version from VERSION.txt). */
#define MOONLAB_VERSION_STRING "@QSIM_VERSION_FULL@"
#define MOONLAB_VERSION_MAJOR  @QSIM_VERSION_MAJOR@
#define MOONLAB_VERSION_MINOR  @QSIM_VERSION_MINOR@
#define MOONLAB_VERSION_PATCH  @QSIM_VERSION_PATCH@

/* Optional subsystems.  1 = compiled in, 0 = not compiled. */
#define MOONLAB_HAS_MPI        @MOONLAB_HAS_MPI@
#define MOONLAB_HAS_METAL      @MOONLAB_HAS_METAL@
#define MOONLAB_HAS_CUDA       @MOONLAB_HAS_CUDA@
#define MOONLAB_HAS_OPENCL     @MOONLAB_HAS_OPENCL@
#define MOONLAB_HAS_VULKAN     @MOONLAB_HAS_VULKAN@
#define MOONLAB_HAS_WEBGPU     @MOONLAB_HAS_WEBGPU@
#define MOONLAB_HAS_CUQUANTUM  @MOONLAB_HAS_CUQUANTUM@
#define MOONLAB_HAS_OPENMP     @MOONLAB_HAS_OPENMP@
#define MOONLAB_HAS_AVX512     @MOONLAB_HAS_AVX512@
#define MOONLAB_HAS_AVX2       @MOONLAB_HAS_AVX2@
#define MOONLAB_HAS_NEON       @MOONLAB_HAS_NEON@
#define MOONLAB_HAS_SVE        @MOONLAB_HAS_SVE@

#endif /* MOONLAB_FEATURES_H */
