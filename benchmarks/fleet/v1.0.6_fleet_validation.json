      "notes": "ARMv8.2 Carmel + integrated GPU; CPU lane validated here, GPU lane is v1.1 arc"
    }
  },
  "experiments": {
    "ghz_sharding_validation": {
      "binary": "examples/distributed/large_state_ghz",
      "host": "old-donkey",
      "points": [
        {
          "N": 30,
          "ranks": 8,
          "state_gib": 16,
          "wall_s": 20.5,
          "verified": true,
          "notes": "P(|0...0>)=P(|1...1>)=0.5"
        },
        {
          "N": 31,
          "ranks": 8,
          "state_gib": 32,
          "wall_s": 37.7,
          "verified": true,
          "notes": "post-buffer-overflow-fix"
        },
        {
          "N": 32,
          "ranks": 8,
          "state_gib": 64,
          "wall_s": 86.2,
          "verified": true,
          "notes": "post-buffer-overflow-fix"
        },
        {
          "N": 33,
          "ranks": 16,
          "state_gib": 128,
          "wall_s": 144.1,
          "verified": true,
          "notes": "biggest sharded state validated"
        },
        {
          "N": 26,
          "ranks": 4,
          "state_gib": 1,
          "wall_s": 1.83,
          "verified": true,
          "host": "xavier",
          "notes": "first aarch64 + jetpack-nixos run on the fleet; cross-arch MPI w/ x86_64 hosts works"
        },
        {
          "N": 28,
          "ranks": 8,
          "state_gib": 4,
          "wall_s": 5.46,
          "verified": true,
          "host": "xavier",
          "notes": "ARM NEON+SVE lane exercised; near 30 GB RAM ceiling"
        }
      ],
      "bug_discovered_and_fixed": {
        "symptom": "glibc free(): invalid size at N>=31",
        "cause": "src/distributed/state_partition.c capped send/recv buffer at 1 GB while distributed_gates.c assumed buffer holds local_count amplitudes (4 GiB+ at N>=31)",
        "fix": "drop 1 GB cap; size to local_count unconditionally",
        "commit": "919305b"
      },
      "additional_portability_fix": {
        "symptom": "snprintf implicit declaration on gcc-aarch64 in src/optimization/simd_sve.c",
        "cause": "transitive include of <stdio.h> via SVE intrinsics + glibc differs from x86_64; aarch64 build with SVE has no implicit stdio",
        "fix": "explicit #include <stdio.h>"
      }
    },
    "cross_host_load": {
      "binary": "tools/fleet_loadtest.py",
      "scenarios": [
        {
          "clients_host": "cosbox",
          "workers": 8,
          "duration_s": 5,
          "tenant": null,
          "tls": false,
          "rps": 19.6,
          "p50_ms": 413,
          "errors": 0
        },
        {
          "clients_host": "cosbox+old-donkey",
          "workers": "64+64",
          "duration_s": 8,
          "tenant": null,
          "tls": false,
          "rps_aggregate": 300,
          "p50_ms": 421,
          "errors": 84,
          "note": "84/2401=3.5% backpressure on max-concurrent=64 server"
        },
        {
          "clients_host": "cosbox",
          "workers": 16,
          "duration_s": 5,
          "tenant": "acme-corp",
          "tls": false,
          "rps": 41.4,
          "p50_ms": 399,
          "errors": 0
        },
        {
          "clients_host": "cosbox+old-donkey+atlas-loopback",
          "workers": "64+64+16",
          "duration_s": 10,
          "tenant": "3 distinct IDs",
          "tls": false,
          "rps_aggregate": 3653,
          "p50_ms_atlas": 4.3,
          "p50_ms_fleet": 408,
          "errors": 472,
          "note": "atlas localhost saturates at 3377 rps; 3 tenant IDs verified"
        }
      ]
    },
    "cross_host_tls": {
      "binary": "tools/fleet_loadtest.py --tls --tls-ca",
