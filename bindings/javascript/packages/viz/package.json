{
  "name": "@moonlab/quantum-viz",
  "version": "1.1.0",
  "description": "Quantum state visualizations for Moonlab",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./canvas": {
      "types": "./dist/canvas/index.d.ts",
      "import": "./dist/canvas/index.mjs",
      "require": "./dist/canvas/index.js"
    },
    "./webgl": {
      "types": "./dist/webgl/index.d.ts",
      "import": "./dist/webgl/index.mjs",
      "require": "./dist/webgl/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/canvas/index.ts src/webgl/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "quantum",
    "visualization",
    "bloch-sphere",
    "webgl",
    "canvas"
  ],
  "author": "Moonlab",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tsotchke/moonlab.git",
    "directory": "bindings/javascript/packages/viz"
  },
  "homepage": "https://github.com/tsotchke/moonlab#readme",
  "bugs": "https://github.com/tsotchke/moonlab/issues",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@moonlab/quantum-core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "vitest": "^1.0.0"
  },
  "sideEffects": false
}
